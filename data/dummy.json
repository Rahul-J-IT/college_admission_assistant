def get_ranking(ctype, nirf_base, college_name):
    global nirf_counter
    nirf = nirf_base + random.randint(0, 50)
    cat = "Engineering" if "Engineering" in ctype else ("Medical" if "Medical" in ctype else "Arts & Science")
    return {"NIRF_2024": nirf, "state_rank": random.randint(1, 30), "category": cat}

