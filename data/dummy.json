        picked = random.sample(med_courses, min(2, len(med_courses)))
        for i, (name, dur, seats, minpct, subjects, exams, fee) in enumerate(picked):
            courses.append({
                "id": make_course_id(col_idx, i+1),
                "name": name,
                "duration": f"{dur} years",
                "seats": seats,
                "eligibility": {
                    "min_percentage": minpct,
