        ]
        picked = random.sample(arts_courses, min(2, len(arts_courses)))
        for i, (name, dur, seats, minpct, subjects, fee) in enumerate(picked):
            courses.append({
                "id": make_course_id(col_idx, i+1),
                "name": name,
                "duration": f"{dur} years",
                "seats": seats,
                "eligibility": {
                    "min_percentage": minpct,
