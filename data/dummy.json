def make_course_id(col_idx, course_idx):
    return f"CRS{col_idx:03d}{course_idx:02d}"

def make_college_id(idx):
    return f"COL{idx:04d}"

def get_course_by_type(ctype, col_idx):
    courses = []
    if "Engineering" in ctype:
        branches = [
            ("B.E. Computer Science and Engineering", "CSE", 120, 75, ["Physics","Chemistry","Mathematics"], ["TNEA"]),
            ("B.E. Electronics and Communication Engineering", "ECE", 60, 72, ["Physics","Chemistry","Mathematics"], ["TNEA"]),
            ("B.E. Mechanical Engineering", "MECH", 60, 70, ["Physics","Chemistry","Mathematics"], ["TNEA"]),
            ("B.E. Civil Engineering", "CIVIL", 60, 65, ["Physics","Chemistry","Mathematics"], ["TNEA"]),
            ("B.E. Information Technology", "IT", 60, 70, ["Physics","Chemistry","Mathematics"], ["TNEA"]),
            ("B.Tech Artificial Intelligence and Data Science", "AIDS", 60, 72, ["Physics","Chemistry","Mathematics"], ["TNEA"]),
        ]
        picked = random.sample(branches, min(2, len(branches)))
        for i, (name, code, seats, minpct, subjects, exams) in enumerate(picked):
            fee = random.choice([45000, 50000, 60000, 70000, 90000, 125000, 185000, 198000])
            courses.append({
                "id": make_course_id(col_idx, i+1),
                "name": name,
                "duration": "4 years",
                "seats": seats,
                "eligibility": {
                    "min_percentage": minpct,
                    "required_subjects": subjects,
                    "entrance_exams": exams,
                    "age_limit": "17-25 years"
                },
                "fees": {
                    "tuition_per_year": fee,
                    "hostel_per_year": random.choice([25000, 28000, 30000, 35000, 40000, 60000, 90000]),
                    "other_fees": random.choice([5000, 7000, 8000, 10000, 15000])
                },
                "application": {
                    "start_date": "2025-04-01",
                    "end_date": "2025-06-30",
                    "result_date": "2025-07-18",
                    "admission_date": "2025-08-03"
                },
                "required_documents": [
                    "10th Mark Sheet","12th Mark Sheet","Transfer Certificate",
                    "Community Certificate","Nativity Certificate","Aadhar Card",
                    f"Passport Size Photos ({random.choice([6,8,10])})","TNEA Rank Card"
                ],
                "reservation_quota": {
                    "OC":"31%","BC":"26.5%","BCM":"3.5%","MBC":"20%","SC":"15%","ST":"3.5%"
